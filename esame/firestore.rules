rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isActiveTerminal() {
      return signedIn()
        && exists(/databases/$(database)/documents/terminali/$(request.auth.uid))
        && get(/databases/$(database)/documents/terminali/$(request.auth.uid)).data.stato == "attivo";
    }

    match /admins/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update, delete: if isAdmin();
    }

    match /terminali/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.stato == "in_attesa"
        && request.resource.data.keys().hasOnly([
          "stato",
          "nome",
          "puntoAccesso",
          "appVersion",
          "modelloTelefono",
          "creatoIl",
          "ultimoOnline"
        ]);

      allow update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "ultimoOnline",
            "appVersion",
            "modelloTelefono",
            "ultimaLetturaUid",
            "ultimaLetturaAt",
            "ultimaTimbraturaTipo",
            "ultimaTimbraturaAt"
          ])
        );

      allow delete: if isAdmin();
    }

    match /badge/{uid} {
      allow read: if isAdmin() || isActiveTerminal();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isActiveTerminal()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "ultimoUtilizzo",
            "ultimoEsito",
            "ultimoTipoTimbratura",
            "ultimoTerminale"
          ])
        );
    }

    match /dipendenti/{idDipendente} {
      allow read: if isAdmin() || isActiveTerminal();
      allow create, update, delete: if isAdmin();
    }

    match /letture_grezze/{idLettura} {
      allow create: if signedIn()
        && request.resource.data.terminalId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "uid",
          "uidFormato",
          "tipoBadge",
          "tecnologie",
          "terminalId",
          "appVersion",
          "modelloTelefono",
          "dataOra"
        ]);

      allow read, update, delete: if isAdmin();
    }

    match /accessi/{idAccesso} {
      allow create: if isAdmin()
        || (
          isActiveTerminal()
          && request.resource.data.terminalId == request.auth.uid
          && request.resource.data.keys().hasOnly([
            "uid",
            "uidFormato",
            "tipoBadge",
            "idDipendente",
            "nomeCompleto",
            "puntoAccesso",
            "terminalId",
            "tipoTimbratura",
            "esito",
            "motivo",
            "modalitaDemo",
            "dataOperativa",
            "oraRegistrata",
            "oraPrevista",
            "orarioPrevistoInizio",
            "orarioPrevistoFine",
            "orarioPausaInizio",
            "orarioPausaFine",
            "ritardoMinuti",
            "uscitaAnticipataMinuti",
            "straordinarioMinuti",
            "oreLavorateMinuti",
            "penalitaMinuti",
            "penalitaOre",
            "penalitaEuro",
            "pagaOrariaSimulata",
            "demoScenarioEntrata",
            "demoScenarioUscita",
            "dataOra",
            "registratoIl"
          ])
        );

      allow read: if isAdmin()
        || (isActiveTerminal() && resource.data.terminalId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /presenze_giornaliere/{idPresenza} {
      allow read: if isAdmin() || isActiveTerminal();

      allow create, update: if isAdmin()
        || (
          isActiveTerminal()
          && request.resource.data.terminalId == request.auth.uid
          && request.resource.data.keys().hasOnly([
            "idDipendente",
            "nomeCompleto",
            "dataOperativa",
            "terminalId",
            "aggiornatoIl",
            "prossimaTimbratura",
            "ultimoTipo",
            "ultimoOrario",
            "ultimoMotivo",
            "ultimaEntrataAt",
            "ultimaEntrataOra",
            "ultimaUscitaAt",
            "ultimaUscitaOra",
            "ritardoMinuti",
            "uscitaAnticipataMinuti",
            "straordinarioMinuti",
            "oreLavorateMinuti",
            "penalitaMinuti",
            "penalitaOre",
            "penalitaEuro",
            "resetDemoIl",
            "resetDemoDa"
          ])
        );

      allow delete: if isAdmin();
    }

    match /impostazioni_demo/{doc} {
      allow read: if isAdmin() || isActiveTerminal();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
